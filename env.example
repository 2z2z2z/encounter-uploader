# =============================================================================
# Переменные окружения для Encounter Uploader
# Согласно плану рефакторинга (Фаза 6.2)
# =============================================================================

# Основные настройки
NODE_ENV=production
BUILD_TARGET=production

# API и сервер
API_BASE_URL=http://localhost:3001
PORT=3001

# Безопасность сессий (Фаза 6.3)
SESSION_SECRET=your-super-secret-session-key-change-this-in-production
SESSION_STORE=redis
TRUST_PROXY=true

# Redis настройки (Фаза 6.3)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password

# Логирование
LOG_LEVEL=info

# Development настройки (для разработки)
# NODE_ENV=development
# BUILD_TARGET=development
# SESSION_STORE=memory
# TRUST_PROXY=false
# LOG_LEVEL=debug

# =============================================================================
# Инструкции по использованию:
# =============================================================================
# 1. Скопируйте этот файл как .env
# 2. Измените SESSION_SECRET на случайную строку длиной 32+ символа
# 3. Если используете Redis, настройте REDIS_URL и REDIS_PASSWORD
# 4. В production обязательно установите TRUST_PROXY=true если за nginx/proxy
# 5. Настройте LOG_LEVEL: error, warn, info, debug

# Генерация SESSION_SECRET:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

